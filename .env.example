# AMP GAME SERVER PANEL
AMP_URL=
AMP_USER=
AMP_PASSWORD=

# Django Settings
DJANGO_SECRET_KEY=

# Domain (set to your root domain in production, e.g. example.com)
# Defaults to 'localhost' — leave blank for local development
BASE_DOMAIN=
# DASHBOARD_DOMAIN=dashboard.example.com  # defaults to dashboard.<BASE_DOMAIN>
# EXTRA_ALLOWED_HOSTS=                     # comma-separated extra hosts if needed

# Discovery Approvers
DISCOVERY_APPROVERS=

# Auth: Django built-in auth (username + password) — Authentik SSO coming in Phase 2
# No OIDC credentials needed here until Authentik is installed

# Discord OAuth2 — dashboard bot login (DISCORD_REDIRECT_URI) + QuestLog account linking (DISCORD_REDIRECT_URI_QL)
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# DISCORD_REDIRECT_URI=
# DISCORD_REDIRECT_URI_QL=

# Discord Bot Token (WardenBot)
DISCORD_BOT_TOKEN=

# Your Discord server invite URL (shown in sidebar and game server listings)
DISCORD_INVITE_URL=

# Your site logo URL for Discord embed thumbnails (e.g. https://yourdomain.com/static/img/logo.png)
SITE_LOGO_URL=

# Discord webhook for game suggestions (server-side only - NEVER put in client JS)
# Create at: Discord Server Settings -> Integrations -> Webhooks
GAME_SUGGESTION_WEBHOOK=

# Warden Database (MySQL)
WARDEN_DB_NAME=
WARDEN_DB_USER=
WARDEN_DB_PASSWORD=
WARDEN_DB_HOST=
WARDEN_DB_PORT=
WARDEN_DB_SOCKET=

# IGDB (Internet Game Database) API - Get credentials from https://dev.twitch.tv/console/apps
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
DISCORD_BOT_API_URL=
DISCORD_BOT_API_TOKEN=

# Stripe API Keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
BOT_OWNER_ID=
BOT_OWNER_MAIN_SERVER=

# Django Web App Database
DJANGO_DB_NAME=questlog_web
DJANGO_DB_USER=
DJANGO_DB_PASSWORD=
DJANGO_DB_HOST=
DJANGO_DB_PORT=

# YouTube API Credentials
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_API_KEY=
YOUTUBE_REDIRECT_URI=

# ENCRYPTION_KEY (REQUIRED - app will not start without this)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Audit log IP hashing salt (auto-generated if not set, but set for consistency)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AUDIT_LOG_SALT=

# Email (SMTP for verification emails)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Twitch API Credentials (for Streaming Integration)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=
TWITCH_REDIRECT_URI_QL=

# YouTube QuestLog Web OAuth Redirect
YOUTUBE_REDIRECT_URI_QL=
